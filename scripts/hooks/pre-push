#!/bin/bash
# Pre-push Hook — Heavy Gate (~60s)
# Tier 1.5 D2: verify.sh quick, 95+ 미달 시 push 차단
# SKIP_VERIFY=1 환경변수로 긴급 우회 가능 (audit log 기록)

set -u

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

# venv 활성화
if [ -f ".venv/bin/activate" ]; then
    source .venv/bin/activate
fi

# 긴급 우회
if [ "${SKIP_VERIFY:-0}" = "1" ]; then
    echo "⚠️  SKIP_VERIFY=1 — pre-push heavy gate bypassed"
    echo "    [$(date -Iseconds)] SKIP_VERIFY bypass" >> .omc/logs/skip_verify.log 2>/dev/null || true
    exit 0
fi

echo ""
echo "┌─────────────────────────────────────┐"
echo "│  Pre-push Heavy Gate (verify.sh)    │"
echo "└─────────────────────────────────────┘"
echo ""

# verify.sh quick 실행
VERIFY_OUTPUT=$(bash scripts/verify.sh quick 2>&1)
VERIFY_EXIT=$?

echo "$VERIFY_OUTPUT"

# 점수 파싱 (★ 표시용 — verify.sh 동적 MAX, deferred 제외 반영)
TOTAL=$(echo "$VERIFY_OUTPUT" | grep -oP 'TOTAL:\s*\K[0-9]+' | tail -1)
MAX=$(echo "$VERIFY_OUTPUT" | grep -oP 'TOTAL:\s*[0-9]+/\K[0-9]+' | tail -1)
MAX=${MAX:-100}

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Pre-push 점수: ${TOTAL:-?}/${MAX}  (gate: verify.sh 동적 95%)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ★ verify.sh가 최종 판정자 — 동적 MAX(deferred 제외) + hard gate(SHIP_BLOCKED)
#   + threshold 95%를 모두 반영해 exit code 반환. pre-push는 그 결과를 신뢰한다.
#   (TOTAL/100 고정 비교는 deferred 동적 MAX 도입 전 가정 — 일관성 버그였음)
if [ "$VERIFY_EXIT" -eq 0 ]; then
    echo "✅ PASSED ($TOTAL/$MAX — verify.sh PASSED) — push 진행"
    exit 0
else
    echo "❌ FAILED ($TOTAL/$MAX — verify.sh FAILED) — push 차단"
    echo ""
    echo "   해결 방법:"
    echo "     scripts/verify.sh quick   # 상세 확인"
    echo "     SKIP_VERIFY=1 git push    # 긴급 우회"
    exit 1
fi
