#!/bin/bash
# Pre-commit Hook — Lite Gate (~30s)
# Tier 1.5 D2: Ruff + Mypy (warning) + Hook Gate + pytest --lf
# 실패 시 commit 차단. Verify/Smoke는 pre-push에서만.

set -u

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

# venv 활성화 (없으면 시스템 Python 사용)
if [ -f ".venv/bin/activate" ]; then
    source .venv/bin/activate
fi

echo ""
echo "┌─────────────────────────────────────┐"
echo "│  Pre-commit Lite Gate               │"
echo "└─────────────────────────────────────┘"

FAIL=0

# [1] Ruff lint
echo ""
echo "[1/4] Ruff lint..."
if ruff check core/ service/ tools/ tests/ --quiet 2>/dev/null; then
    echo "  ✅ ruff OK"
else
    echo "  ❌ ruff FAILED — run: ruff check . --fix"
    FAIL=1
fi

# [2] Mypy (warning-only, non-blocking)
echo ""
echo "[2/4] Mypy type check (warning-only)..."
if mypy core/ service/ --strict --no-error-summary 2>/dev/null | tail -3; then
    echo "  ✅ mypy OK"
else
    echo "  ⚠️  mypy warnings (non-blocking)"
fi

# [3] Hook Gate — staged diff → HookManager.trigger(post_code)
echo ""
echo "[3/4] Hook Gate (anti-pattern + pkg check)..."
STAGED_DIFF="$(git diff --cached 2>/dev/null)"
if [ -n "$STAGED_DIFF" ]; then
    if echo "$STAGED_DIFF" | python scripts/run_hook.py post_code 2>/dev/null; then
        echo "  ✅ Hook Gate OK"
    else
        echo "  ❌ Hook Gate FAILED"
        FAIL=1
    fi
else
    echo "  ✅ Hook Gate OK (no staged changes)"
fi

# [4] pytest --lf (last-failed only; first run = all)
#     실패 시 AutoFixer max 3 사이클 자동 시도
echo ""
echo "[4/4] pytest --lf (last-failed, AutoFix on fail)..."
if pytest tests/unit/ --lf -q --tb=short 2>/dev/null; then
    echo "  ✅ pytest OK"
else
    echo "  ⚠️  pytest failed — trying AutoFixer (max 3 cycles)..."
    if python -c "
from pathlib import Path
from core.harness.auto_fix import AutoFixer
r = AutoFixer(Path('.')).fix_all()
if r.final_success:
    print('  ✅ AutoFixer fixed issues')
    exit(0)
else:
    print(r.escalation_message)
    exit(1)
" 2>/dev/null; then
        echo "  ✅ AutoFixer OK"
    else
        echo "  ❌ AutoFixer failed — manual fix required"
        FAIL=1
    fi
fi

echo ""
if [ "$FAIL" -eq 0 ]; then
    echo "✅ Pre-commit Lite PASSED — proceeding to commit"
    exit 0
else
    echo "❌ Pre-commit Lite FAILED — commit blocked"
    echo "   Fix errors above, then retry."
    exit 1
fi
