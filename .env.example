# WorldFork 환경 변수
# 사용: cp .env.example .env && 본인 값 입력

# LLM API (Tier 0부터 필수)
ANTHROPIC_API_KEY=your-key-here

# Tier 0 verifier (Cross-Model)
OPENAI_API_KEY=your-key-here

# Tier 1+ (선택, 지금은 비활성)
# GOOGLE_API_KEY=your-key-here

# 비용 한도 (USD)
WORLDFORK_DAILY_LIMIT_USD=5.00

# 디버그
WORLDFORK_DEBUG=false

# Layer 1 ship gate에서 사용 (Cross-Model 강제)
WORLDFORK_DEV_MODEL=claude-code

# ★ Tier 2 D11: CORS allowed origins (콤마 구분)
# 본인 PC frontend 환경에 맞춰 설정
# 예시:
#   localhost: http://localhost:4000
#   Tailscale: http://100.70.109.50:4000
#   회사 LAN: http://192.168.x.x:4000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://100.70.109.50:4000
